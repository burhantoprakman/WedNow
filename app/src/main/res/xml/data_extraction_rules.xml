<?xml version="1.0" encoding="utf-8"?><!--
    Data Extraction Rules (API 31+).
    Controls what is included in cloud backups and device-to-device transfers.

    See: https://developer.android.com/about/versions/12/backup-restore#xml-changes
-->
<data-extraction-rules>
    <cloud-backup>
        <!--
            Exclude authentication and identity data.
            Auth state is re-established via Firebase on first launch after restore.
            Restoring a stale identity would silently link the restored device to
            the original device's Firestore guest document.
        -->
        <exclude
            domain="sharedpref"
            path="wednow_identity.xml" />
        <!--
            Exclude device-local guest session data.
            The guest UUID is device-specific — transferring it would merge two
            separate devices' identities on the Firestore side.
        -->
        <exclude
            domain="sharedpref"
            path="wedding_app.xml" />
    </cloud-backup>

    <device-transfer>
        <!-- Same exclusions apply for device-to-device (e.g. Setup Wizard restore). -->
        <exclude
            domain="sharedpref"
            path="wednow_identity.xml" />
        <exclude
            domain="sharedpref"
            path="wedding_app.xml" />
    </device-transfer>
</data-extraction-rules>
