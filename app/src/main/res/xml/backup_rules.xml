<?xml version="1.0" encoding="utf-8"?><!--
    Cloud Backup rules (API 30 and below).
    For API 31+ see data_extraction_rules.xml.

    Excluded SharedPreferences:
      • wednow_identity — contains user email, display name, auth provider, linked IDs
      • wedding_app     — contains device-local guest UUID and guest display name

    These are excluded because:
    1. Auth state should be re-established via Firebase on first launch.
    2. Guest UUIDs are device-specific — restoring them to another device would
       silently merge identities in Firestore.
-->
<full-backup-content>
    <exclude
        domain="sharedpref"
        path="wednow_identity.xml" />
    <exclude
        domain="sharedpref"
        path="wedding_app.xml" />
</full-backup-content>
